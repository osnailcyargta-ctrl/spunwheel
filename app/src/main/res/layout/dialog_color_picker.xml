<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#0E0E11"
    android:paddingBottom="32dp">

    <View android:layout_width="36dp" android:layout_height="4dp"
        android:background="#2A2A2E" android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp" android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginBottom="16dp">

        <View
            android:id="@+id/color_preview"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="14dp"/>

        <EditText
            android:id="@+id/edit_hex"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="#16161A"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:paddingStart="14dp"
            android:singleLine="true"
            android:inputType="text"
            android:hint="#RRGGBB"
            android:hintTextColor="#333333"
            android:fontFamily="monospace"/>
    </LinearLayout>

    <GridLayout
        android:id="@+id/color_grid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="5"
        android:layout_gravity="center_horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="20dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <TextView
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Batal"
            android:textColor="#555555"
            android:textSize="15sp"
            android:background="#16161A"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/btn_ok"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Pilih"
            android:textColor="#000000"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="#FFFFFF"/>
    </LinearLayout>

</LinearLayout>
